# =====================================================================
# Git Attributes for Developer Workspace
# Controls how Git handles different file types
# =====================================================================

# === AUTO DETECT TEXT FILES ===
* text=auto

# === SOURCE CODE ===
*.py text eol=lf diff=python
*.js text eol=lf diff=javascript
*.jsx text eol=lf diff=javascript
*.ts text eol=lf diff=typescript
*.tsx text eol=lf diff=typescript
*.gd text eol=lf
*.json text eol=lf
*.jsonc text eol=lf

# === WEB FILES ===
*.html text eol=lf diff=html
*.css text eol=lf diff=css
*.scss text eol=lf diff=css
*.sass text eol=lf diff=css
*.xml text eol=lf

# === SHELL SCRIPTS ===
*.sh text eol=lf
*.bash text eol=lf
*.zsh text eol=lf

# === DOCUMENTATION ===
*.md text eol=lf diff=markdown
*.txt text eol=lf
*.rst text eol=lf
*.adoc text eol=lf

# === CONFIGURATION FILES ===
*.yml text eol=lf
*.yaml text eol=lf
*.toml text eol=lf
*.ini text eol=lf
*.cfg text eol=lf
*.conf text eol=lf
*.config text eol=lf
.editorconfig text eol=lf
.gitignore text eol=lf
.gitattributes text eol=lf
Makefile text eol=lf
Dockerfile text eol=lf

# === GODOT FILES ===
*.tscn text eol=lf merge=union
*.tres text eol=lf merge=union
*.godot text eol=lf
*.import text eol=lf

# === LOCK FILES (binary) ===
package-lock.json binary
yarn.lock binary
poetry.lock binary
Pipfile.lock binary

# === BINARIES ===
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.svg binary
*.webp binary
*.bmp binary

# === AUDIO / VIDEO ===
*.mp3 binary
*.mp4 binary
*.wav binary
*.ogg binary
*.flac binary
*.mov binary
*.avi binary
*.webm binary

# === FONTS ===
*.ttf binary
*.otf binary
*.woff binary
*.woff2 binary
*.eot binary

# === DOCUMENTS ===
*.pdf binary
*.doc binary
*.docx binary
*.xls binary
*.xlsx binary
*.ppt binary
*.pptx binary

# === ARCHIVES ===
*.zip binary
*.tar binary
*.gz binary
*.tgz binary
*.rar binary
*.7z binary

# === EXECUTABLES ===
*.exe binary
*.dll binary
*.so binary
*.dylib binary
*.app binary
*.dmg binary
*.pkg binary

# === COMPILED ===
*.pyc binary
*.pyo binary
*.class binary
*.o binary
*.a binary

# === DATABASE ===
*.db binary
*.sqlite binary
*.sqlite3 binary

# === UNITY / GAME ENGINE (if needed) ===
*.unity binary
*.prefab binary
*.mat binary
*.asset binary

# === EXPORT AS ARCHIVES ===
# Mark certain file patterns for export
*.export-ignore export-ignore

# === LINGUIST OVERRIDES ===
# Help GitHub detect languages correctly
*.gd linguist-language=GDScript
*.tscn linguist-language=GDScript linguist-generated=false
*.tres linguist-language=GDScript linguist-generated=false
docs/** linguist-documentation
templates/** linguist-vendored

# === MERGE STRATEGIES ===
# Custom merge for specific files
*.lock merge=ours
CHANGELOG.md merge=union

# === DIFF SETTINGS ===
# Better diff output for certain files
*.ipynb diff=jupyternotebook
