# ================================================================================
# Hostinger SFTP Deployment Configuration
# ================================================================================
#
# SETUP INSTRUCTIONS:
# 1. Copy this file to your project root: cp .hostinger-config.example .hostinger-config
# 2. Get credentials from Hostinger Panel:
#    → Login: https://hpanel.hostinger.com
#    → Go to: Hosting → Your Domain → Manage → Files → FTP Accounts
# 3. Edit .hostinger-config with your actual credentials
# 4. Add .hostinger-config to .gitignore (NEVER commit credentials!)
#
# ================================================================================

# ────────────────────────────────────────────────────────────────────────────
# REQUIRED: Hostinger FTP Credentials
# ────────────────────────────────────────────────────────────────────────────

# SFTP Hostname
# Usually: ftp.yourdomain.com or IP address
# Find in: Hostinger Panel → FTP Accounts → Hostname
HOSTINGER_HOST="ftp.yourdomain.com"

# FTP Username  
# Format: u123456789 or username@yourdomain.com
# Find in: Hostinger Panel → FTP Accounts → Username
HOSTINGER_USER="u123456789"

# FTP Password
# The password you set when creating the FTP account
HOSTINGER_PASSWORD="your_password_here"

# ────────────────────────────────────────────────────────────────────────────
# REQUIRED: Directory Configuration
# ────────────────────────────────────────────────────────────────────────────

# Remote directory on Hostinger server
# Common options:
#   - Main domain:        public_html
#   - Subdomain:          public_html/subdomain
#   - Subfolder:          public_html/portfolio
#   - Addon domain:       public_html/addondomain.com
REMOTE_DIR="public_html"

# Local build directory (where your built files are)
# Common options:
#   - Vite/React:         dist
#   - Create React App:   build
#   - Next.js:            out
#   - Static site:        . (current directory)
#   - Custom:             public
LOCAL_BUILD_DIR="dist"

# ────────────────────────────────────────────────────────────────────────────
# OPTIONAL: Project Configuration
# ────────────────────────────────────────────────────────────────────────────

# Project type (auto-detects if not specified)
# Options: static, react, nextjs, php
# - static:  No build step, uploads as-is
# - react:   Runs 'npm run build', expects dist/ or build/
# - nextjs:  Runs 'npm run build', expects out/ (static export only)
# - php:     No build step, uploads PHP files
PROJECT_TYPE="react"

# Files/directories to exclude from upload (space-separated)
# These patterns are passed to lftp's --exclude option
EXCLUDE_FILES=".git node_modules .env .DS_Store .vscode .idea"

# Create backup before deployment (yes/no)
# Backups saved to: backups/hostinger-YYYYMMDD-HHMMSS/
# Recommended: yes (can restore if something goes wrong)
CREATE_BACKUP="yes"

# ────────────────────────────────────────────────────────────────────────────
# EXAMPLES for Different Scenarios
# ────────────────────────────────────────────────────────────────────────────

# Example 1: Main Domain - React App
# HOSTINGER_HOST="ftp.mywebsite.com"
# HOSTINGER_USER="u987654321"
# REMOTE_DIR="public_html"
# LOCAL_BUILD_DIR="dist"
# PROJECT_TYPE="react"

# Example 2: Subdomain - Next.js Static Export
# HOSTINGER_HOST="ftp.mywebsite.com"
# HOSTINGER_USER="u987654321"  
# REMOTE_DIR="public_html/app"
# LOCAL_BUILD_DIR="out"
# PROJECT_TYPE="nextjs"

# Example 3: Subfolder - Static Portfolio
# HOSTINGER_HOST="ftp.mywebsite.com"
# HOSTINGER_USER="u987654321"
# REMOTE_DIR="public_html/portfolio"
# LOCAL_BUILD_DIR="."
# PROJECT_TYPE="static"

# Example 4: PHP Project
# HOSTINGER_HOST="ftp.mywebsite.com"
# HOSTINGER_USER="u987654321"
# REMOTE_DIR="public_html"
# LOCAL_BUILD_DIR="."
# PROJECT_TYPE="php"
# EXCLUDE_FILES=".git .env vendor/test"

# ────────────────────────────────────────────────────────────────────────────
# NOTES
# ────────────────────────────────────────────────────────────────────────────
#
# 🔐 Security:
#   - NEVER commit .hostinger-config to Git
#   - Add to .gitignore: echo ".hostinger-config" >> .gitignore
#   - Use strong passwords, change regularly
#
# 📁 Hostinger Directory Structure:
#   public_html/              ← Main domain root
#   ├── index.html           ← https://yourdomain.com
#   ├── subdomain/           ← https://subdomain.yourdomain.com
#   └── blog/                ← https://yourdomain.com/blog
#
# 🚀 Deployment Commands:
#   deploy-to-hostinger.sh --init        # Create config in project
#   deploy-to-hostinger.sh --build       # Build and deploy
#   deploy-to-hostinger.sh               # Deploy existing build
#   deploy-to-hostinger.sh --no-backup   # Deploy without backup
#   deploy-to-hostinger.sh --dry-run     # Preview files to upload
#
# 📦 Build Directories by Tool:
#   - Vite:              dist/
#   - Create React App:  build/
#   - Next.js Export:    out/
#   - Parcel:            dist/
#   - Vue CLI:           dist/
#   - Angular:           dist/
#
# ⚙️ Next.js Static Export Required:
#   Add to next.config.js:
#   module.exports = {
#     output: 'export',
#     images: { unoptimized: true }
#   }
#
# 🆘 Troubleshooting:
#   - Connection failed? Check hostname, username, password in Hostinger Panel
#   - Permission denied? Verify FTP user has write access
#   - 404 errors? Check REMOTE_DIR matches your domain/subdomain setup
#   - Old content? Clear browser cache (Cmd+Shift+R)
#
# ================================================================================
