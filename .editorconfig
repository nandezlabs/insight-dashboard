# EditorConfig helps maintain consistent coding styles across different editors and IDEs
# More info: https://editorconfig.org

# Top-most EditorConfig file
root = true

# =====================================================================
# Universal Settings (All Files)
# =====================================================================
[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
max_line_length = 120

# =====================================================================
# Python Files
# =====================================================================
[*.py]
indent_style = space
indent_size = 4
max_line_length = 88  # Black formatter default

[*.{pyi,pyx}]
indent_style = space
indent_size = 4

# =====================================================================
# JavaScript / TypeScript / JSON
# =====================================================================
[*.{js,jsx,ts,tsx,mjs,cjs}]
indent_style = space
indent_size = 2
quote_type = single

[*.{json,jsonc}]
indent_style = space
indent_size = 2

# =====================================================================
# Web Files (HTML, CSS, SCSS)
# =====================================================================
[*.{html,htm}]
indent_style = space
indent_size = 2

[*.{css,scss,sass,less}]
indent_style = space
indent_size = 2

# =====================================================================
# Markdown
# =====================================================================
[*.md]
indent_style = space
indent_size = 2
trim_trailing_whitespace = false
max_line_length = off

# =====================================================================
# Godot / GDScript
# =====================================================================
[*.gd]
indent_style = tab
indent_size = 4
charset = utf-8

[*.{tscn,tres,godot,import}]
indent_style = tab
indent_size = 4

# =====================================================================
# YAML / TOML
# =====================================================================
[*.{yml,yaml}]
indent_style = space
indent_size = 2

[*.toml]
indent_style = space
indent_size = 4

# =====================================================================
# Shell Scripts
# =====================================================================
[*.{sh,bash,zsh}]
indent_style = space
indent_size = 2
end_of_line = lf

# =====================================================================
# Configuration Files
# =====================================================================
[{package.json,package-lock.json,yarn.lock}]
indent_style = space
indent_size = 2

[{Makefile,makefile,*.mk}]
indent_style = tab
indent_size = 4

[{.gitignore,.gitattributes,.dockerignore}]
indent_style = space
indent_size = 2

[Dockerfile*]
indent_style = space
indent_size = 2

# =====================================================================
# Swift (iOS Development)
# =====================================================================
[*.swift]
indent_style = space
indent_size = 4

[*.{pbxproj,storyboard,xib}]
indent_style = tab
indent_size = 4

# =====================================================================
# SQL
# =====================================================================
[*.sql]
indent_style = space
indent_size = 2

# =====================================================================
# XML / SVG
# =====================================================================
[*.{xml,svg,plist}]
indent_style = space
indent_size = 2

# =====================================================================
# Special Cases
# =====================================================================
[*.csv]
trim_trailing_whitespace = false

[*.tsv]
indent_style = tab
trim_trailing_whitespace = false

[LICENSE]
insert_final_newline = false
