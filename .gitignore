# =====================================================================
# Developer Workspace .gitignore
# Comprehensive ignore rules for multi-language development
# =====================================================================

# === MACOS ===
.DS_Store
.AppleDouble
.LSOverride
._*
.DocumentRevisions-V100
.fseventsd
.Spotlight-V100
.TemporaryItems
.Trashes
.VolumeIcon.icns
.com.apple.timemachine.donotpresent
.AppleDB
.AppleDesktop
Network Trash Folder
Temporary Items
.apdisk

# === WINDOWS ===
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
ehthumbs_vista.db
*.stackdump
[Dd]esktop.ini
$RECYCLE.BIN/
*.cab
*.msi
*.msix
*.msm
*.msp
*.lnk

# === LINUX ===
*~
.fuse_hidden*
.directory
.Trash-*
.nfs*

# === NODE / NPM / YARN ===
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
.npm
.yarn/cache
.yarn/unplugged
.yarn/build-state.yml
.yarn/install-state.gz
.pnp.*
lerna-debug.log*
.eslintcache
.cache/
.parcel-cache/

# === PYTHON ===
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
share/python-wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# Python Virtual Environments
venv/
env/
ENV/
.venv/
.env/
virtualenv/
pipenv/
.python-version
.pytest_cache/
.coverage
.coverage.*
htmlcov/
.tox/
.nox/
.hypothesis/
*.cover
*.py,cover
.mypy_cache/
.dmypy.json
dmypy.json
.pyre/
.pytype/

# Jupyter Notebook
.ipynb_checkpoints
*.ipynb_checkpoints/

# === GODOT ===
.godot/
.import/
export.cfg
export_presets.cfg
*.translation
.mono/
data_*/
android/
ios/
builds/

# === WEB / FRONTEND ===
dist/
.next/
out/
.nuxt/
.cache/
.vuepress/dist
.serverless/
.fusebox/
.dynamodb/
.tern-port
.vscode-test
